{
  "headers": [
    {
      "source": "/:path*.(jpg|jpeg|png|gif|svg)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        },
        {
          "key": "Expires",
          "value": "Thu, 31 Dec 2037 23:55:55 GMT"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.quicktoolhub.tech"
        }
      ],
      "destination": "https://quicktoolhub.tech/:path*",
      "statusCode": 301
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "quicktoolhub.tech"
        },
        {
          "type": "header",
          "key": "x-forwarded-proto",
          "value": "http"
        }
      ],
      "destination": "https://quicktoolhub.tech/:path*",
      "statusCode": 301
    }
  ]
}
